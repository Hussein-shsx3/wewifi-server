                        placeholder="DD/MM/YYYY">
                    </div>
                    <div class="profile-form-group">
                      <label>تاريخ اول اتصال</label>
                      <input type="text" id="profileFirstContactDate" name="firstContactDate" class="profile-input"
                        placeholder="DD/MM/YYYY">
                    </div>
                    <div class="profile-form-group full-width">
                      <label>تاريخ الفصل</label>
                      <input type="text" id="profileDisconnectionDate" readonly class="profile-input readonly"
                        title="يتم حسابه تلقائياً">
                    </div>
                    <div class="profile-form-group full-width">
                      <label>ملاحظات</label>
                      <textarea id="profileNotes" name="notes" rows="2" class="profile-textarea"></textarea>
                    </div>
                  </div>
                  <div class="profile-form-actions">
                    <button type="submit" class="profile-btn profile-btn-primary">حفظ التعديلات</button>
                  </div>
                </form>
              </div>
            </div>

            <!-- Right Column - Actions & History -->
            <div class="profile-column profile-column-side">
              <!-- Change Username Card -->
              <div class="profile-card">
                <div class="profile-card-header">
                  <h3>تغيير اسم المستخدم</h3>
                </div>
                <div class="profile-card-body username-change-body">
                  <div class="profile-form-grid compact-grid">
                    <div class="profile-form-group">
                      <label>اسم المستخدم الجديد</label>
                      <input type="text" id="newUsernameInput" class="profile-input"
                        placeholder="أدخل اسم المستخدم الجديد">
                    </div>
                    <div class="profile-form-group">
                      <label>السرعة المطلوبة</label>
                      <select id="newUsernameTargetSpeed" class="profile-select">
                        <option value="4">4 ميجا</option>
                        <option value="8">8 ميجا</option>
                      </select>
                    </div>
                  </div>
                  <p class="profile-hint" id="newUsernameSpeedMatchHint">اختر اسم مستخدم جديد وسرعة مطلوبة.</p>
                  <div class="profile-form-group">
                    <label>كلمة المرور الجديدة</label>
                    <input type="text" id="newPasswordInput" class="profile-input"
                      placeholder="أدخل كلمة المرور الجديدة">
                  </div>
                  <button type="button" class="profile-btn profile-btn-primary full-width" id="changeUsernameBtn">تغيير
                    اسم المستخدم</button>
                  <p class="profile-hint">سيتم حفظ البيانات القديمة في السجل</p>
                </div>
              </div>

              <!-- Assign from Available Card -->
              <div class="profile-card">
                <div class="profile-card-header">
                  <h3>تعيين من المتاحة</h3>
                </div>
                <div class="profile-card-body">
                  <div class="profile-form-group">
                    <label>اختر اسم مستخدم</label>
                    <select id="availableUsernameSelect" class="profile-select">
                      <option value="">اختر اسم مستخدم متاح...</option>
                    </select>
                  </div>
                  <button type="button" class="profile-btn profile-btn-success full-width"
                    id="assignAvailableUsernameBtn">تعيين</button>
                  <p class="profile-hint">سيتم تغيير السرعة تلقائياً حسب نوع الاسم</p>
                </div>
              </div>

              <!-- Username History Card -->
              <div class="profile-card">
                <div class="profile-card-header">
                  <h3>سجل الأسماء السابقة</h3>
                  <button type="button" class="history-add-btn" id="toggleAddHistoryBtn" title="إضافة سجل يدوي">
                    <i class="fas fa-plus"></i>
                  </button>
                </div>

                <!-- Add History Form (hidden by default) -->
                <div class="history-add-form" id="addHistoryForm" style="display: none;">
                  <div class="history-form-row">
                    <div class="history-form-field">
                      <label>اسم المستخدم القديم <span class="required">*</span></label>
                      <input type="text" id="historyOldUsername" placeholder="اسم المستخدم" />
                    </div>
                    <div class="history-form-field">
                      <label>كلمة المرور القديمة</label>
                      <input type="text" id="historyOldPassword" placeholder="كلمة المرور" />
                    </div>
                  </div>
                  <div class="history-form-row">
                    <div class="history-form-field">
                      <label>تاريخ طلب الاشتراك</label>
                      <input type="date" id="historyStartDate" />
                    </div>
                    <div class="history-form-field">
                      <label>تاريخ النهاية</label>
                      <input type="date" id="historyEndDate" />
                    </div>
                  </div>
                  <div class="history-form-actions">
                    <button type="button" class="profile-btn profile-btn-success" id="saveHistoryEntryBtn">
                      <i class="fas fa-check"></i> حفظ
                    </button>
                    <button type="button" class="profile-btn profile-btn-secondary" id="cancelAddHistoryBtn">
                      إلغاء
                    </button>
                  </div>
                </div>

                <div class="profile-card-body">
                  <div class="profile-history-list" id="usernameHistoryList">
                    <div class="profile-history-empty">لا توجد بيانات سابقة</div>
                  </div>
                  <!-- Hidden table for backward compatibility -->
                  <table style="display:none;">
                    <tbody id="usernameHistoryTableBody"></tbody>
                  </table>
                </div>
              </div>

              <!-- Speed History Card -->
              <div class="profile-card">
                <div class="profile-card-header">
                  <h3>سجل تغيير السرعة</h3>
                </div>
                <div class="profile-card-body">
                  <div class="profile-history-list" id="speedHistoryList">
                    <div class="profile-history-empty">لا توجد بيانات سابقة</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

      </div>
    </main>
  </div>

  <!-- Import Excel Modal -->
  <div id="importExcelModal" class="modal" style="display: none;">
    <div class="modal-content import-modal-content">
      <div class="modal-header">
        <h3>استيراد ملف Excel</h3>
        <button class="close-modal-btn" onclick="closeImportModal()">×</button>
      </div>

      <div class="modal-body">
        <!-- Upload Type Selection -->
        <div class="upload-type-selector">
          <label class="upload-type-option">
            <input type="radio" name="uploadType" value="new" checked>
            <span class="type-card">
              <strong>استيراد مشتركين جدد</strong>
              <small>إضافة أو تحديث المشتركين بناءً على اسم المستخدم</small>
            </span>
          </label>
          <label class="upload-type-option">
            <input type="radio" name="uploadType" value="update">
            <span class="type-card">
              <strong>تحديث بيانات الدخول بالـ ID</strong>
              <small>تحديث اسم المستخدم وكلمة المرور فقط باستخدام ID المشترك</small>
            </span>
          </label>
        </div>

        <div class="upload-info" id="updateInfo" style="display: none;">
          <div class="info-box">
            <strong>📋 صيغة ملف التحديث:</strong>
            <p>يجب أن يحتوي الملف على الأعمدة التالية:</p>
            <ul>
              <li><code>ID</code> - رقم المشترك (مطلوب)</li>
              <li><code>اسم المستخدم</code> أو <code>Username</code> - اسم المستخدم الجديد (اختياري)</li>
              <li><code>كلمة المرور</code> أو <code>Password</code> - كلمة المرور الجديدة (اختياري)</li>
              <li><code>التاريخ</code> - تاريخ طلب الاشتراك (اختياري)</li>
            </ul>
            <p style="font-size: 12px; color: var(--text-light); margin-top: 10px;">💡 يمكنك تحديث أي حقل أو جميع الحقول
              معاً</p>
          </div>
        </div>

        <div class="upload-container">
          <div class="upload-area" id="uploadArea">
            <p>اسحب وأفلت ملف Excel هنا</p>
            <p class="or-text">أو</p>
            <input type="file" id="excelFile" name="excelFile" accept=".xlsx,.xls" style="display: none;">
            <button type="button" class="btn btn-primary modern-btn" id="chooseFileBtn">
              اختر ملف
            </button>
          </div>

          <div id="uploadResult" class="upload-result">
            <div id="uploadMessage" class="message"></div>
            <div id="uploadStats" class="stats"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stop Subscriber Modal - Outside main container -->
  <div id="stopSubscriberModal" class="modal-overlay" style="display: none;">
    <div class="modal-box">
      <h3>إيقاف المشترك</h3>
      <p style="margin-bottom: 15px; color: #666;">هل أنت متأكد من إيقاف هذا المشترك؟ سيتم نقله إلى قسم المشتركين
        المتوقفين وإعادة اسم المستخدم للأسماء المتاحة.</p>
      <div class="input-group">
        <label>سبب الإيقاف (اختياري)</label>
        <input type="text" id="stopReasonInput" placeholder="مثال: عدم التجديد، طلب العميل...">
      </div>
      <div class="modal-actions">
        <button type="button" class="action-btn danger" onclick="confirmStopSubscriber()">تأكيد الإيقاف</button>
        <button type="button" class="action-btn secondary" onclick="closeStopSubscriberModal()">إلغاء</button>
      </div>
    </div>
  </div>

  <!-- Speed Change Username Selection Modal -->
  <div id="speedChangeUsernameModal" class="modal-overlay" style="display: none;">
    <div class="modal-box">
      <h3>اختيار اسم مستخدم جديد</h3>
      <p style="margin-bottom: 15px; color: #666;">
        عند تغيير السرعة، يجب اختيار اسم مستخدم جديد للسرعة <strong id="speedChangeSpeedLabel">8 ميجا</strong>.
        <br>
        سيتم إرجاع اسم المستخدم الحالي للأسماء المتاحة مع أيامه المتبقية.
      </p>
      <div class="input-group">
        <label>اختر اسم المستخدم الجديد</label>
        <select id="speedChangeUsernameSelect" class="form-select">
          <option value="">-- اختر اسم مستخدم --</option>
        </select>
      </div>
      <div class="modal-actions">
        <button type="button" class="action-btn primary" onclick="confirmSpeedChangeUsername()">تأكيد التغيير</button>
        <button type="button" class="action-btn secondary" onclick="closeSpeedChangeUsernameModal()">إلغاء</button>
      </div>
    </div>
  </div>

  <script src="/js/dashboard.js"></script>
</body>

</html>