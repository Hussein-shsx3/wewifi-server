<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>لوحة التحكم - إدارة المشتركين</title>
  <!-- Font Awesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <!-- Google Fonts -->
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Cairo:wght@400;600;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>
  <div class="container">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <img src="/images/logo.png" alt="شعار الشركة" class="logo">
        <h2>WeWifi</h2>
      </div>

      <nav class="sidebar-menu">
        <ul>
          <li><a href="#dashboard" class="menu-item active" data-section="dashboard">الرئيسية</a></li>
          <li><a href="#subscribers" class="menu-item" data-section="subscribers">المشتركون</a></li>
          <li><a href="#expiring-usernames" class="menu-item" data-section="expiring-usernames">انتهاء الصلاحية</a></li>
          <li><a href="#stopped-subscribers" class="menu-item" data-section="stopped-subscribers">المشتركون
              المتوقفون</a></li>
          <li><a href="#available-usernames" class="menu-item" data-section="available-usernames">أسماء مستخدمين
              متاحة</a></li>
          <li><a href="#sms" class="menu-item" data-section="sms"><i class="fas fa-comment-sms"></i> رسائل SMS</a></li>
          <li><a href="/logout" class="menu-item logout">تسجيل الخروج</a></li>
        </ul>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <!-- Header -->
      <header class="top-header">
        <div class="header-left">
          <button class="menu-toggle" id="menuToggle" aria-label="تبديل القائمة">☰</button>
          <h1>لوحة تحكم المشتركين</h1>
        </div>
        <div class="header-right">
          <span class="user-info">المسؤول</span>
        </div>
      </header>

      <!-- Content Sections -->
      <div class="content">

        <!-- Dashboard Section -->
        <section id="dashboard" class="section active">
          <!-- Dashboard Header -->
          <div class="dashboard-header">
            <div class="dashboard-title-group">
              <h2 class="dashboard-title"><i class="fas fa-chart-line"></i> لوحة التحكم الرئيسية</h2>
              <p class="dashboard-subtitle">نظرة شاملة وتفصيلية على أداء النظام</p>
            </div>
            <div class="dashboard-date-badge">
              <i class="fas fa-calendar-alt"></i>
              <span id="currentDate">اليوم</span>
            </div>
          </div>

          <!-- KPI Cards Grid -->
          <div class="kpi-grid">
            <!-- Total Subscribers Card -->
            <div class="kpi-card primary-gradient">
              <div class="kpi-icon-wrapper">
                <i class="fas fa-users"></i>
              </div>
              <div class="kpi-content">
                <span class="kpi-label">إجمالي المشتركين</span>
                <h3 class="kpi-value" id="totalSubscribers">0</h3>
                <span class="kpi-trend" id="newSubscribersWeek">
                  <i class="fas fa-arrow-up"></i> +0 هذا الأسبوع
                </span>
              </div>
            </div>

            <!-- Available Usernames Card -->
            <div class="kpi-card success-gradient">
              <div class="kpi-icon-wrapper">
                <i class="fas fa-list"></i>
              </div>
              <div class="kpi-content">
                <span class="kpi-label">أسماء مستخدمين متاحة</span>
                <h3 class="kpi-value" id="availableUsernamesCount">0</h3>
                <span class="kpi-trend" id="availableAddedWeek">
                  <i class="fas fa-arrow-up"></i> +0 هذا الأسبوع
                </span>
              </div>
            </div>

            <!-- Expiring Soon Card -->
            <div class="kpi-card warning-gradient">
              <div class="kpi-icon-wrapper">
                <i class="fas fa-exclamation-triangle"></i>
              </div>
              <div class="kpi-content">
                <span class="kpi-label">تنتهي قريباً</span>
                <h3 class="kpi-value" id="aboutToDisconnectCount">0</h3>
                <span class="kpi-trend warning-text">خلال 7 أيام</span>
              </div>
            </div>

            <!-- Expired Subscriptions Card -->
            <div class="kpi-card danger-gradient">
              <div class="kpi-icon-wrapper">
                <i class="fas fa-times-circle"></i>
              </div>
              <div class="kpi-content">
                <span class="kpi-label">منتهية الصلاحية</span>
                <h3 class="kpi-value" id="expiredCount">0</h3>
                <span class="kpi-trend danger-text">تحتاج تجديد فوري</span>
              </div>
            </div>
          </div>

          <!-- Analytics Section -->
          <div class="analytics-section">
            <!-- Speed Distribution - Donut Chart -->
            <div class="analytics-card">
              <div class="card-header">
                <h3><i class="fas fa-tachometer-alt"></i> توزيع السرعات</h3>
                <span class="card-badge">هذا الشهر</span>
              </div>
              <div class="card-body">
                <div class="donut-chart-container">
                  <div class="donut-chart-wrapper">
                    <canvas id="speedDonutChart" width="180" height="180"></canvas>
                    <div class="donut-center-text">
                      <span class="donut-total" id="speedDonutTotal">0</span>
                      <span class="donut-total-label">إجمالي</span>
                    </div>
                  </div>
                  <div class="donut-legend">
                    <div class="legend-item">
                      <span class="legend-dot" style="background: #f5a623;"></span>
                      <span class="legend-label">4 ميجا</span>
                      <span class="legend-value" id="speed4mCount">0</span>
                    </div>
                    <div class="legend-item">
                      <span class="legend-dot" style="background: #0891b2;"></span>
                      <span class="legend-label">8 ميجا</span>
                      <span class="legend-value" id="speed8mCount">0</span>
                    </div>
                  </div>
                </div>
                <!-- Hidden bars for backward compatibility -->
                <div style="display:none;">
                  <div id="speed4mBar"></div>
                  <div id="speed8mBar"></div>
                </div>
              </div>
            </div>

            <!-- Weekly Activity -->
            <div class="analytics-card">
              <div class="card-header">
                <h3><i class="fas fa-chart-bar"></i> نشاط هذا الأسبوع</h3>
              </div>
              <div class="card-body">
                <div class="activity-metrics">
                  <div class="metric-box">
                    <div class="metric-icon new-subscribers">
                      <i class="fas fa-user-plus"></i>
                    </div>
                    <div class="metric-info">
                      <span class="metric-value" id="weekNewSubscribers">0</span>
                      <span class="metric-label">مشتركين جدد</span>
                    </div>
                  </div>
                  <div class="metric-box">
                    <div class="metric-icon new-usernames">
                      <i class="fas fa-plus-circle"></i>
                    </div>
                    <div class="metric-info">
                      <span class="metric-value" id="weekAvailableAdded">0</span>
                      <span class="metric-label">أسماء مضافة</span>
                    </div>
                  </div>
                  <div class="metric-box">
                    <div class="metric-icon speed-changes">
                      <i class="fas fa-bolt"></i>
                    </div>
                    <div class="metric-info">
                      <span class="metric-value" id="weekSpeedChanges">0</span>
                      <span class="metric-label">تغييرات سرعة</span>
                    </div>
                  </div>
                  <div class="metric-box">
                    <div class="metric-icon username-changes">
                      <i class="fas fa-sync"></i>
                    </div>
                    <div class="metric-info">
                      <span class="metric-value" id="weekUsernameChanges">0</span>
                      <span class="metric-label">تغييرات أسماء</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Details Section -->
          <div class="details-section">
            <!-- Available Usernames Status -->
            <div class="analytics-card">
              <div class="card-header">
                <h3><i class="fas fa-hourglass-half"></i> حالة الأسماء المتاحة</h3>
              </div>
              <div class="card-body">
                <div class="status-bars">
                  <div class="status-bar-item">
                    <div class="status-bar-header">
                      <span class="status-label"><i class="fas fa-circle" style="color: #10b981;"></i> كاملة (31
                        يوم)</span>
                      <span class="status-count" id="fullDaysCount">0</span>
                    </div>
                    <div class="status-bar">
                      <div class="status-progress full" id="fullDaysProgress"></div>
                    </div>
                  </div>
                  <div class="status-bar-item">
                    <div class="status-bar-header">
                      <span class="status-label"><i class="fas fa-circle" style="color: #f59e0b;"></i> متوسطة (15-30
                        يوم)</span>
                      <span class="status-count" id="halfDaysCount">0</span>
                    </div>
                    <div class="status-bar">
                      <div class="status-progress half" id="halfDaysProgress"></div>
                    </div>
                  </div>
                  <div class="status-bar-item">
                    <div class="status-bar-header">
                      <span class="status-label"><i class="fas fa-circle" style="color: #f97316;"></i> منخفضة (7-14
                        يوم)</span>
                      <span class="status-count" id="quarterDaysCount">0</span>
                    </div>
                    <div class="status-bar">
                      <div class="status-progress quarter" id="quarterDaysProgress"></div>
                    </div>
                  </div>
                  <div class="status-bar-item">
                    <div class="status-bar-header">
                      <span class="status-label"><i class="fas fa-circle" style="color: #ef4444;"></i> حرجة (أقل من 7
                        أيام)</span>
                      <span class="status-count" id="lowDaysCount">0</span>
                    </div>
                    <div class="status-bar">
                      <div class="status-progress low" id="lowDaysProgress"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Recent Changes -->
            <div class="analytics-card">
              <div class="card-header">
                <h3><i class="fas fa-history"></i> آخر التغييرات</h3>
              </div>
              <div class="card-body">
                <div class="recent-changes-list" id="recentSpeedChangesList">
                  <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <p>لا توجد تغييرات حديثة</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- New Subscribers -->
            <div class="analytics-card">
              <div class="card-header">
                <h3><i class="fas fa-user-plus"></i> مشتركون جدد</h3>
              </div>
              <div class="card-body">
                <div class="recent-changes-list" id="recentNewSubscribersList">
                  <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <p>لا توجد إضافات حديثة</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Username Changed Today -->
            <div class="analytics-card">
              <div class="card-header">
                <h3><i class="fas fa-user-edit"></i> تغييرات اسم المستخدم اليوم</h3>
              </div>
              <div class="card-body">
                <div class="recent-changes-list" id="todayUsernameChangesList">
                  <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <p>لا توجد تغييرات اليوم</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Expiring Soon -->
            <div class="analytics-card">
              <div class="card-header">
                <h3><i class="fas fa-bell"></i> تحتاج تجديد</h3>
                <a href="#expiring-usernames" class="see-all-link">عرض الكل <i class="fas fa-arrow-left"></i></a>
              </div>
              <div class="card-body">
                <div class="expiring-list" id="aboutToDisconnectList">
                  <div class="empty-state">
                    <i class="fas fa-check-circle"></i>
                    <p>لا توجد اشتراكات تنتهي قريباً 🎉</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Quick Actions Footer -->
          <div class="quick-actions-footer">
            <a href="#subscribers" class="action-btn">
              <i class="fas fa-users-cog"></i>
              <span>إدارة المشتركين</span>
            </a>
            <a href="#available-usernames" class="action-btn">
              <i class="fas fa-file-list"></i>
              <span>أسماء المستخدمين</span>
            </a>
            <a href="#expiring-usernames" class="action-btn">
              <i class="fas fa-clock"></i>
              <span>انتهاء الصلاحية</span>
            </a>
            <a href="#stopped-subscribers" class="action-btn">
              <i class="fas fa-ban"></i>
              <span>المشتركون المتوقفون</span>
            </a>
          </div>
        </section>

        <!-- SMS Section -->
        <section id="sms" class="section sms-section">
          <div class="sms-layout">
            <div class="sms-card">
              <div class="section-header sms-header">
                <div class="sms-header-title">
                  <h2><i class="fas fa-comment-sms"></i> إرسال رسالة SMS</h2>
                  <p class="sms-subtitle">ارسل تذكيراً بالتجديد أو رسالة تسويقية للمشتركين بسهولة</p>
                </div>
                <div class="sms-meta">
                  <span class="sms-provider-badge"><i class="fas fa-signal"></i> TweetSMS</span>
                  <span class="sms-limit-text">حتى 320 حرف لكل رسالة</span>
                </div>
              </div>

              <form id="smsForm" class="sms-form">
                <div class="sms-recipient-toggle">
                  <label>
                    <input type="radio" name="smsRecipientType" value="subscriber" checked>
                    <span>من المشتركين</span>
                  </label>
                  <label>
                    <input type="radio" name="smsRecipientType" value="custom">
                    <span>رقم آخر</span>
                  </label>
                </div>

                <div class="input-group search-group" id="smsSubscriberGroup">
                  <label for="smsSubscriberSearch">ابحث عن المشتركين (بالاسم أو الهاتف)</label>
                  <div class="search-wrapper">
                    <input type="text" id="smsSubscriberSearch" placeholder="اكتب اسم المشترك أو رقم الهاتف..."
                      autocomplete="off">
                    <ul id="smsSuggestions" class="suggestions-list" role="listbox" aria-label="اقتراحات المشتركين"></ul>
                  </div>
                  <div class="sms-selected-toolbar">
                    <span id="smsSelectedCountBadge" class="sms-selected-count">المحددون: 0</span>
                    <button type="button" id="smsClearSelectedBtn" class="sms-clear-selected-btn">مسح المحددين</button>
                  </div>
                  <div id="smsSelectedRecipients" class="sms-selected-recipients"></div>
                  <p class="field-hint">يمكنك اختيار أكثر من مشترك. اختر من القائمة لإضافة المستلم.</p>
                </div>

                <div class="input-group" id="smsCustomPhoneGroup" style="display: none;">
                  <label for="smsCustomPhone">رقم الجوال</label>
                  <input type="tel" id="smsCustomPhone" placeholder="أدخل رقم الجوال يدوياً (مثال: 0599xxxxxx)">
                  <p class="field-hint">يمكنك إرسال رسالة لأي رقم حتى لو لم يكن ضمن قائمة المشتركين.</p>
                </div>

                <div class="input-group">
                  <div class="sms-textarea-header">
                    <label for="smsMessage">نص الرسالة</label>
                    <span id="smsCharCount" class="sms-char-counter">0 / 320</span>
                  </div>
                  <textarea id="smsMessage" name="message" rows="4" required maxlength="320"
                    placeholder="اكتب رسالتك هنا بشكل واضح ومختصر..."></textarea>
                  <p class="field-hint">استخدم لغة بسيطة، واذكر اسم الشبكة ومدة الاشتراك أو العرض إن وجد.</p>
                </div>

                <div class="form-actions sms-actions">
                  <button type="submit" class="action-btn primary">
                    <i class="fas fa-paper-plane"></i>
                    <span>إرسال الرسالة</span>
                  </button>
                </div>
              </form>
            </div>

            <aside class="sms-side-panel">
              <h3><i class="fas fa-lightbulb"></i> نصائح للرسائل الناجحة</h3>
              <ul>
                <li>عرّف بالمُرسل في بداية الرسالة (مثال: WeWifi).</li>
                <li>اذكر سبب الرسالة بوضوح مثل تذكير بالتجديد أو عرض جديد.</li>
                <li>اختم بدعوة لاتصال أو واتساب للتواصل السريع.</li>
              </ul>
              <div class="sms-side-note">
                <i class="fas fa-info-circle"></i>
                <span>يمكنك الإرسال لعدة مشتركين دفعة واحدة أو إلى رقم مخصص.</span>
              </div>
            </aside>
          </div>
        </section>

        <!-- Subscribers Section -->
        <section id="subscribers" class="section">
          <div class="section-header">
            <h2>إدارة المشتركين</h2>
            <div class="header-buttons">
              <button class="btn btn-primary modern-btn" id="addSubscriberBtn">
                إضافة مشترك
              </button>
              <button class="btn btn-info modern-btn" id="importExcelBtn" title="استيراد من Excel">
                استيراد Excel
              </button>
              <button class="btn btn-success modern-btn" id="exportExcelBtn" title="تصدير إلى Excel">
                تصدير Excel
              </button>
              <button class="btn btn-secondary modern-btn" id="exportBackupExcelBtn" title="تصدير نسخة احتياطية كاملة">
                نسخة احتياطية Excel
              </button>
              <button class="btn btn-warning modern-btn" id="bulkEditBtn" style="display: none;" title="تعديل المحددين">
                تعديل المحددين
              </button>
              <button class="btn btn-danger modern-btn" id="deleteSelectedBtn" style="display: none;"
                title="حذف المحددين">
                حذف المحددين (<span id="selectedCount">0</span>)
              </button>
              <button class="btn btn-danger modern-btn" id="deleteAllBtn" title="حذف جميع المشتركين">
                حذف الكل
              </button>
            </div>
          </div>

          <!-- Bulk Edit Modal -->
          <div id="bulkEditModal" class="modal" style="display: none;">
            <div class="modal-content">
              <h3>تعديل المحددين</h3>
              <p class="modal-info">سيتم تطبيق التغييرات على <span id="bulkEditCount">0</span> مشترك</p>
              <form id="bulkEditForm">
                <div class="form-group">
                  <label for="bulkField">اختر الحقل</label>
                  <select id="bulkField" required>
                    <option value="">اختر...</option>
                    <option value="facilityType">نوع المنشأة</option>
                    <option value="package">الخط</option>

                    <option value="startDate">تاريخ طلب الاشتراك</option>
                    <option value="firstContactDate">تاريخ اول اتصال</option>
                    <option value="speed">السرعة</option>
                    <option value="notes">ملاحظات</option>
                  </select>
                </div>
                <div class="form-group" id="bulkValueGroup" style="display: none;">
                  <label for="bulkValue">القيمة الجديدة</label>
                  <input type="text" id="bulkValue" placeholder="أدخل القيمة الجديدة">
                  <input type="date" id="bulkValueDate" style="display: none;">
                </div>
                <div class="form-actions">
                  <button type="submit" class="btn btn-success modern-btn">تطبيق التعديلات</button>
                  <button type="button" class="btn btn-secondary modern-btn" id="cancelBulkEdit">إلغاء</button>
                </div>
              </form>
            </div>
          </div>
          <!-- Add/Edit Form -->
          <div id="subscriberForm" class="form-container" style="display: none;">
            <div class="form-card">
              <h3 id="formTitle">إضافة مشترك جديد</h3>
              <form id="subscriberFormElement">
                <div class="form-group">
                  <label for="availableUsernameForNewSubscriber">اسم المستخدم (من المتاحة)</label>
                  <select id="availableUsernameForNewSubscriber" name="availableUsernameId" required>
                    <option value="">اختر اسم مستخدم متاح...</option>
                  </select>
                  <small style="display:block; margin-top:6px; color:#666;">يتم سحب اسم المستخدم وكلمة المرور تلقائياً من
                    الأسماء المتاحة</small>
                </div>

                <div class="form-group">
                  <label for="fullName">اسم الزبون</label>
                  <input type="text" id="fullName" name="fullName" placeholder="أدخل اسم الزبون">
                </div>

                <div class="form-group">
                  <label for="facilityType">نوع المنشأة</label>
                  <select id="facilityType" name="facilityType">
                    <option value="">اختر نوع المنشأة</option>
                    <option value="متجر هواتف">متجر هواتف</option>
                    <option value="متجر ملابس">متجر ملابس</option>
                    <option value="صالون رجالي">صالون رجالي</option>
                    <option value="محل خياطة">محل خياطة</option>
                    <option value="مطبعة">مطبعة</option>
                    <option value="صيدلية">صيدلية</option>
                    <option value="مطعم شاورما">مطعم شاورما</option>
                    <option value="مطعم فلافل">مطعم فلافل</option>
                    <option value="ماركت">ماركت</option>
                    <option value="متجر أدوات منزلية">متجر أدوات منزلية</option>
                    <option value="متجر سجائر">متجر سجائر</option>
                    <option value="فري لانسر">فري لانسر</option>
                    <option value="محل صرافة">محل صرافة</option>
                    <option value="متجر احذية">متجر احذية</option>
                    <option value="عيادة اسنان">عيادة اسنان</option>
                    <option value="محل تصليح">محل تصليح</option>
                    <option value="أخرى">أخرى</option>
                  </select>
                  <input type="text" id="facilityTypeOther" class="profile-input" placeholder="اكتب نوع المنشأة"
                    style="display: none; margin-top: 8px;">
                </div>

                <div class="form-group">
                  <label for="phone">رقم الجوال</label>
                  <input type="tel" id="phone" name="phone" placeholder="أدخل رقم الجوال">
                </div>

                <div class="form-group">
                  <label for="package">الخط</label>
